# Root-level env example for local development.
# The web app reads from apps/web/.env.local — see apps/web/.env.example for the
# authoritative, fully-commented list. This file mirrors the variables you
# typically need when running `bun run web` from the repo root.

# --- Minimum runtime ---
POSTGRES_URL=
BETTER_AUTH_SECRET=
# Public origin used by better-auth for callbacks (local dev: http://localhost:3000).
BETTER_AUTH_URL=http://localhost:3000

# --- Vercel AI Gateway ---
# Routes Anthropic / OpenAI calls (anthropic/* model ids). Wired via OIDC on Vercel,
# only needed for local dev or when running outside Vercel.
AI_GATEWAY_API_KEY=

# --- Vercel OAuth (sign-in) ---
NEXT_PUBLIC_VERCEL_APP_CLIENT_ID=
VERCEL_APP_CLIENT_SECRET=

# --- GitHub App (repo access, pushes, PRs) ---
# Callback URL: {YOUR_ORIGIN}/api/auth/callback/github
# Setup URL:    {YOUR_ORIGIN}/api/github/app/callback
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
# PEM with escaped \n newlines, or base64-encoded PEM
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# --- Optional integrations ---
ELEVENLABS_API_KEY=

# --- Optional Redis / Vercel KV (skills metadata cache; in-memory fallback) ---
REDIS_URL=
KV_URL=

# --- Optional tuning ---
RATE_LIMIT_TIMEOUT_MS=
VERCEL_PROJECT_PRODUCTION_URL=
NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=
VERCEL_SANDBOX_BASE_SNAPSHOT_ID=
